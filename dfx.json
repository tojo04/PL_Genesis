{
  "canisters": {
    "cerebrum_backend": {
      "main": "src/cerebrum_backend/main.mo",
      "type": "motoko"
    },
    "cerebrum_registry": {
      "main": "src/cerebrum_backend/cerebrum_registry/main.mo",
      "type": "motoko"
    },
    "governance": {
      "main": "src/cerebrum_backend/governance/main.mo",
      "type": "motoko",
      "dependencies": [
        "cerebrum_backend",
        "staking",
        "cerebrum_registry"
      ]
    },
    "staking": {
      "main": "src/cerebrum_backend/staking/main.mo",
      "type": "motoko"
    },
    "treasury": {
      "main": "src/cerebrum_backend/treasury/main.mo",
      "type": "motoko"
    },
    "proposals": {
      "main": "src/cerebrum_backend/proposals/main.mo",
      "type": "motoko"
    },
    "assets": {
      "main": "src/cerebrum_backend/assets/main.mo",
      "type": "motoko",
      "init": { "args": "(null, false)" }
    },
    "cerebrum_analytics": {
      "main": "src/cerebrum_backend/analytics/main.mo",
      "type": "motoko"
    },
    "icrc1_ledger": {
      "type": "custom",
      "wasm": "third_party/icrc1/ic-icrc1-ledger.wasm.gz",
      "candid": "third_party/icrc1/ledger.did"
    },
    "cerebrum_frontend": {
      "dependencies": [
        "cerebrum_backend",
        "cerebrum_registry",
        "governance",
        "staking",
        "treasury",
        "proposals",
        "assets",
        "cerebrum_analytics"
      ],
      "source": [
        "src/cerebrum_frontend/dist"
      ],
      "type": "assets",
      "workspace": "cerebrum_frontend",
      "declarations": {
        "output": "src/cerebrum_frontend/src/declarations"
      }
    },
    "internet_identity": {
      "candid": "https://github.com/dfinity/internet-identity/releases/latest/download/internet_identity.did",
      "frontend": {},
      "type": "custom",
      "wasm": "https://github.com/dfinity/internet-identity/releases/latest/download/internet_identity_dev.wasm.gz"
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:4943",
      "type": "ephemeral"
    },
    "playground": {
      "providers": ["https://ic0.app"],
      "type": "persistent"
    },
    "ic": {
      "providers": ["https://ic0.app"],
      "type": "persistent"
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "output_env_file": ".env",
  "version": 1
}
