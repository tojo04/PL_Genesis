{
  "name": "dao_frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "dev:clean": "npm run clean:cache && npm run dev",
    "clean:cache": "rimraf node_modules/.vite .vite-cache",
    "setup": "npm i",
    "start": "vite",
    "prebuild": "echo 'Building NeuraVault frontend'",
    "build": "vite build",
    "format": "prettier --write \"src/**/*.{json,js,jsx,ts,tsx,css,scss}\"",
    "test": "vitest run",
    "demo:e2e": "node ./scripts/e2e-neuravault-demo.mjs"
  },
  "dependencies": {
    "@onflow/fcl": "^1.20.0",
    "framer-motion": "^11.18.2",
    "lit-js-sdk": "^1.1.250",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^3.2.0",
    "web3.storage": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.32",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.2",
    "vite-plugin-environment": "^1.1.3",
    "vitest": "^1.5.0"
  }
}
